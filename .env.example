# Formless 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# Convex (Next.js client/server)
NEXT_PUBLIC_CONVEX_URL=https://your-convex-project.convex.cloud
# Server-only: used by Next.js API routes to call Convex internal functions
CONVEX_ADMIN_TOKEN=your_convex_admin_token_here

# Clerk 配置
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_key_here
CLERK_SECRET_KEY=sk_test_your_key_here

# Admin allowlist (comma-separated email addresses)
ADMIN_EMAILS=admin@example.com

# Clerk 路由配置
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/chat
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/chat

# Convex auth (set via `npx convex env set` for dev/prod deployments)
# CLERK_JWT_ISSUER_DOMAIN=https://your-clerk-issuer-domain.clerk.accounts.dev
# ADMIN_EMAILS=admin@example.com

# 应用配置
NODE_ENV=development
NEXT_PUBLIC_APP_URL=https://formless.pro

# 可选：日志级别
LOG_LEVEL=info

# ----------------------------------------------------------------------------
# Semantic memory recall (cross-session passive embedding)
# ----------------------------------------------------------------------------
# Default: reuses OPENROUTER_API_KEYS and routes openai/text-embedding-3-small
# through OpenRouter — zero extra setup.
#
# Set to `openai` and populate OPENAI_API_KEY if OpenRouter does not proxy
# the embedding model reliably for your account.
# EMBEDDING_PROVIDER=openrouter
# OPENAI_API_KEY=sk-...
#
# The same EMBEDDING_PROVIDER / OPENAI_API_KEY vars must also be set on the
# Convex deployment (via `npx convex env set`) so the async embedding
# generation action can reach the provider.

# E2E 测试账号（本地/CI 使用）
E2E_USER_EMAIL=
E2E_USER_PASSWORD=
